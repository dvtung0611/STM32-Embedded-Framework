{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "STM32 BareMetal Firmware Debug",
            "type": "cortex-debug",
            "request": "launch",
            "cwd": "${workspaceRoot}",

            "executable": "${workspaceRoot}/build/${env:BOARD}/firmware.elf",

            "servertype": "openocd",

            "configFiles": [
                "interface/stlink.cfg",
                "${workspaceRoot}/boards/${env:BOARD}/openocd.cfg"
            ],

            "device": "${env:BOARD}",

            "svdFile": "${workspaceRoot}/svd/${env:MCU}.svd",

            "runToEntryPoint": "main",

            "preLaunchTask": "Build Firmware",

            "swoConfig": {
                "enabled": true,
                "cpuFrequency": 16000000,
                "swoFrequency": 2000000,
                "source": "probe",
                "decoders": [
                    {
                        "port": 0,
                        "type": "console",
                        "label": "ITM Console"
                    }
                ]
            }
        }
    ]
}