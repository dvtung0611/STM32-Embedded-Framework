{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "STM32 BareMetal Debug",
            "type": "cortex-debug",
            "request": "launch",

            "cwd": "${workspaceRoot}",

            "executable": "${workspaceRoot}/stm32f407vgtx.elf",

            "servertype": "openocd",

            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32f4x.cfg"
            ],

            "device": "STM32F407VG",

            "svdFile": "${workspaceRoot}/SVD/STM32F407.svd",

            "runToEntryPoint": "main",

            "preLaunchTask": "Build",

            "swoConfig": {
                "enabled": true,
                "cpuFrequency": 16000000,
                "swoFrequency": 2000000,
                "source": "probe",
                "decoders": [
                    {
                        "port": 0,
                        "type": "console",
                        "label": "ITM Console"
                    }
                ]
            }
        }
    ]
}